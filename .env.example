# Local development — start ClickHouse + Redis with:
#   docker compose up -d --wait

# Basic configuration (matches docker-compose.yml defaults)
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=indexer
CLICKHOUSE_PASSWORD=indexer
CLICKHOUSE_DATABASE=default
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgres://indexer:indexer@localhost:5433/defuse_indexer
REDIS_TTL_SECONDS=900
METRICS_SERVER_PORT=8080
# BlocksAPI data source (required)
BLOCKSAPI_SERVER_ADDR=
BLOCKSAPI_TOKEN=

BLOCK_HEIGHT=0

# Tracing configuration
RUST_LOG=near_defuse_indexer=debug,near_lake_framework=info

# OpenTelemetry configuration for Jaeger (OTLP HTTP)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_SERVICE_NAME=near-defuse-indexer
OTEL_SERVICE_VERSION=0.2.0

# Alternative: OpenTelemetry configuration for OpenObserve
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:5080/api/default/v1/traces
# OTEL_SERVICE_NAME=near-defuse-indexer
# OTEL_SERVICE_VERSION=0.2.0

# Alternative: OpenTelemetry configuration for Grafana Tempo
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:3200/v1/traces
# OTEL_SERVICE_NAME=near-defuse-indexer
# OTEL_SERVICE_VERSION=0.2.0
